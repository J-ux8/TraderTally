# Error Logging Configuration
# Copy this to your .env file and configure as needed

# Enable or disable error logging globally
# Set to 'true' to enable, 'false' to disable
# Default: 'true' in production, can be toggled for testing
EXPO_PUBLIC_ERROR_LOGGING=true

# Sentry DSN for error tracking
# Get this from: https://sentry.io
# Optional - if not provided, Sentry won't be used
# Leave empty to disable Sentry:
EXPO_PUBLIC_SENTRY_DSN=

# Error logging level
# Options: 'debug', 'info', 'warning', 'error'
# Default: 'error'
EXPO_PUBLIC_ERROR_LOG_LEVEL=error

# Enable local error persistence
# Set to 'true' to store errors in local database for offline scenarios
# Set to 'false' to only log to console
# Default: 'true'
EXPO_PUBLIC_ERROR_PERSISTENCE_ENABLED=true

# Maximum errors to keep in local database
# Older errors will be automatically deleted
# Default: 100
EXPO_PUBLIC_MAX_ERROR_HISTORY=100

# Enable error queue processing
# Set to 'true' to automatically retry sending errors when online
# Default: 'true'
EXPO_PUBLIC_ERROR_QUEUE_ENABLED=true

# API endpoint for sending errors
# Set this if you have a custom error collection endpoint
# Leave empty to use local storage only
EXPO_PUBLIC_ERROR_API_ENDPOINT=
